{
  "compilerOptions": {
    /* ===========================
       Project Structure
    ============================ */
    "rootDir": ".",

    /* ===========================
       Node Environment (ESM)
    ============================ */
    "target": "ES2022",               // Compile to stable modern JS
    "module": "NodeNext",             // Modern ESM support
    "moduleResolution": "NodeNext",   // Node ESM import rules
    "lib": ["ES2022"],                // Standard Node runtime lib
    "types": ["node"],                // Enable Node globals

    /* ===========================
       Type Safety
    ============================ */
    "strict": true,
    "skipLibCheck": true,

    /* ===========================
       Output Tools
    ============================ */
    "noEmit": true,                   // Check the root JavaScript source without writing dist files

    /* ===========================
       Module Rules
    ============================ */
    "verbatimModuleSyntax": true,     // Do not rewrite import/export
    "isolatedModules": true,          // Good for build tools + ESM
    "allowImportingTsExtensions": false, // Prevent `.ts` extension imports

    /* ===========================
       Useful Extras
    ============================ */
    "resolveJsonModule": true,        // Allow: import config from "./config.json"
    "allowJs": true                   // This repo currently uses root JavaScript modules
  },

  /* ===========================
     File Inclusion
  ============================ */
  "include": ["*.js", "api/**/*.js", "tests/**/*.js"],
  "exclude": ["node_modules", "dist"]
}
